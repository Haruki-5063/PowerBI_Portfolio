          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "The ",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  },
                  {
                    "value": "most popular time of day",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#efb251"
                    }
                  },
                  {
                    "value": " for our customers to spend money at our Florida locations is around ",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  },
                  {
                    "value": "10 AM",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#efb251"
                    }
                  },
                  {
                    "value": " (No suprise - We are a coffee company, after all).",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": {
                      "propertyIdentifier": {
                        "objectName": "values",
                        "propertyName": "expr"
                      },
                      "selector": {
                        "id": "Value"
                      }
                    },
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  },
                  {
                    "value": " is our highest revenue -generating day of the week while Saturday is our lowest revenue-generating day.",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "What we are noticing, however, is that our sales don't really take off until 7 AM and have all but ended by 8 PM.",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Combined sales before",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  },
                  {
                    "value": " 7 AM and after 7 PM amount only to $24,836",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#efb251"
                    }
                  },
                  {
                    "value": ", a mere ",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  },
                  {
                    "value": "3.6% of our total sales",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#efb251"
                    }
                  },
                  {
                    "value": " at this point in the year.",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Accordingly, our management team is considering",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  },
                  {
                    "value": " reevaluating our opening and closing times",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#efb251"
                    }
                  },
                  {
                    "value": " for all 3 of our new locations to reflect the slower wind-up of sales and the steep drop off in the evening.",
                    "textStyle": {
                      "fontFamily": "DIN",
                      "fontSize": "18pt",
                      "color": "#004c47"
                    }
                  }
                ]
              }
            ]
          }
        }
